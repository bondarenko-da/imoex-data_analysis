{
  "rewrites": [
    {
      "source": "/api/analyze",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/instruments",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}
  ],
  "functions": {
    "api/index.py": {
      "runtime": "python3.11"
    }
  }
}
